# -----------------------------------------------------------------------------
# PYL Field Manager — environment variables
# -----------------------------------------------------------------------------
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local. The .gitignore blocks it; verify before first commit.
# -----------------------------------------------------------------------------

# --- Supabase ----------------------------------------------------------------
# From Supabase Dashboard → Project Settings → API
# URL and anon key are safe to expose to the browser (they go in NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key is server-only. Used by the iCal sync job to bypass RLS.
# Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Sports Connect iCal feed ------------------------------------------------
# Treat as a credential. Stored only here, never logged or returned by the API.
SPORTS_CONNECT_ICAL_URL=https://calendar.bluesombrero.com/api/v1/Calendar?instancekey=leagues&portalId=10693&id=46947147&key=1NIZ8FA4

# --- Vercel Cron -------------------------------------------------------------
# Random secret the cron endpoint checks in the Authorization header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# --- Application config ------------------------------------------------------
# Admin email used to seed the admin coach row. Also used by the login page
# to display helpful text when a non-registered email tries to log in.
ADMIN_EMAIL=meesh@poweryourleague.com

# Base URL the admin "Sync now" button uses to call the internal sync route.
# Local dev: http://localhost:3000 (or :3001 if 3000 is occupied)
# Production: the custom domain, e.g. https://fields.poweryourleague.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
